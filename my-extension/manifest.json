{
  "manifest_version": 3,
  "name": "UI FACECARD",
  "version": "1.0",
  "description": "A simple tool to make ui understandable and simple debugger tool.",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/images/ON.png",
      "32": "assets/images/ON.png",
      "48": "assets/images/ON.png",
      "128": "assets/images/ON.png"
    }
  },
  "icons": {
    "16": "assets/images/ON.png",
    "32": "assets/images/ON.png",
    "48": "assets/images/ON.png",
    "128": "assets/images/ON.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["assets/styles/content.css"]
    }
  ]
}